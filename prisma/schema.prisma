generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id         String   @id @default(cuid())
  name       String
  premise    String
  genre      String?
  mood       String?
  status     String   @default("active")
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events CampaignEvent[]
  characters Character[]
  worldEntities WorldEntity[]
  worldEntityRelations WorldEntityRelation[]
  knowledgeEntries KnowledgeEntry[]
  storyThreads StoryThread[]

  @@index([status, updatedAt])
}

model StoryThread {
  id                       String   @id @default(cuid())
  campaignId               String
  title                    String
  premise                  String
  description              String?
  status                   String   @default("open")
  urgency                  Int
  progressCurrent          Int      @default(0)
  progressTarget           Int
  relatedEntityIds         Json
  nextPossibleDevelopments Json
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status, urgency])
  @@index([campaignId, updatedAt])
}

model KnowledgeEntry {
  id                    String   @id @default(cuid())
  campaignId            String
  title                 String
  content               String
  type                  String
  truthStatus           String
  knownByCharacterIds   Json
  relatedEntityIds      Json
  sourceEventId         String?
  locked                Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, type, updatedAt])
}

model Character {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  concept    String
  archetype  String
  traits     Json
  flaw       String?
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, updatedAt])
}

model WorldEntity {
  id          String   @id @default(cuid())
  campaignId  String
  type        String
  name        String
  summary     String
  description String?
  tags        Json
  status      String   @default("active")
  details     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  outgoingRelations WorldEntityRelation[] @relation("WorldEntityRelationSource")
  incomingRelations WorldEntityRelation[] @relation("WorldEntityRelationTarget")

  @@index([campaignId, type, status])
  @@index([campaignId, updatedAt])
}

model WorldEntityRelation {
  id             String   @id @default(cuid())
  campaignId     String
  sourceEntityId String
  targetEntityId String
  type           String
  description    String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sourceEntity WorldEntity @relation("WorldEntityRelationSource", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntity WorldEntity @relation("WorldEntityRelationTarget", fields: [targetEntityId], references: [id], onDelete: Cascade)

  @@unique([sourceEntityId, targetEntityId, type])
  @@index([campaignId, sourceEntityId])
  @@index([campaignId, targetEntityId])
}

model CampaignEvent {
  id            String   @id @default(cuid())
  campaignId    String
  eventType     String
  timestampReal DateTime @default(now())
  summary       String
  payload       Json
  source        String
  reversible    Boolean  @default(false)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, timestampReal])
}
