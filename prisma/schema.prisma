generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id         String   @id @default(cuid())
  name       String
  premise    String
  genre      String?
  mood       String?
  status     String   @default("active")
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events CampaignEvent[]
  characters Character[]
  worldEntities WorldEntity[]

  @@index([status, updatedAt])
}

model Character {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  concept    String
  archetype  String
  traits     Json
  flaw       String?
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, updatedAt])
}

model WorldEntity {
  id          String   @id @default(cuid())
  campaignId  String
  type        String
  name        String
  summary     String
  description String?
  tags        Json
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, type, status])
  @@index([campaignId, updatedAt])
}

model CampaignEvent {
  id            String   @id @default(cuid())
  campaignId    String
  eventType     String
  timestampReal DateTime @default(now())
  summary       String
  payload       Json
  source        String
  reversible    Boolean  @default(false)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, timestampReal])
}
